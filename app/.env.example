# Firebase Client (public)
NEXT_PUBLIC_FIREBASE_API_KEY=your_api_key_here
NEXT_PUBLIC_FIREBASE_AUTH_DOMAIN=your_project_id.firebaseapp.com
NEXT_PUBLIC_FIREBASE_PROJECT_ID=your_project_id
NEXT_PUBLIC_FIREBASE_STORAGE_BUCKET=your_project_id.appspot.com
NEXT_PUBLIC_FIREBASE_MESSAGING_SENDER_ID=your_sender_id
NEXT_PUBLIC_FIREBASE_APP_ID=your_app_id

# Firebase Admin (server-side)
FIREBASE_ADMIN_PROJECT_ID=your_project_id
FIREBASE_ADMIN_CLIENT_EMAIL=your_service_account_email
FIREBASE_ADMIN_PRIVATE_KEY="your_private_key_here"

# Data encryption key (must be exactly 32 characters)
ENCRYPTION_KEY=your_encryption_key_32_chars_here

# Ad Network API Keys
EXOCLICK_API_KEY=your_exoclick_api_key
ROLLERADS_API_KEY=your_rollerads_api_key
ZEYDOO_API_KEY=your_zeydoo_api_key
PROPUSH_API_KEY=your_propush_api_key

# Email delivery (for scheduled report emails)
EMAIL_HOST=smtp.gmail.com
EMAIL_PORT=587
EMAIL_USER=your_email@gmail.com
EMAIL_PASSWORD=your_email_password

# Auth
NEXTAUTH_URL=http://localhost:3000
NEXTAUTH_SECRET=your_nextauth_secret

# Internal API secret — used by server-side jobs (sync, exports, schedules) to call
# POST /api/notifications/create without user auth. Must match the value set in your
# deployment environment. Generate with: openssl rand -hex 32
INTERNAL_SYNC_SECRET=your_internal_sync_secret_here
