rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    // ========== Helper functions ==========

    function isAuthenticated() {
      return request.auth != null;
    }

    function isOwner(userId) {
      return isAuthenticated() && request.auth.uid == userId;
    }

    function isResourceOwner() {
      return isAuthenticated() && request.auth.uid == resource.data.userId;
    }

    function isImmutableField(field) {
      return !(field in request.resource.data) || request.resource.data[field] == resource.data[field];
    }

    // ========== users collection ==========
    match /users/{userId} {
      allow create: if isAuthenticated()
        && request.auth.uid == userId
        && request.resource.data.uid == request.auth.uid;

      allow read: if isOwner(userId);

      allow update: if isOwner(userId)
        && isImmutableField('createdAt')
        && isImmutableField('uid')
        && isImmutableField('role');

      allow delete: if false;

      // ── networkConfigs subcollection ──────────────────────────────────────
      // Stores per-network configuration (isActive, syncSchedule, etc.).
      // Writes go through server-side Admin SDK; rules protect direct client access.
      match /networkConfigs/{networkId} {
        allow read: if isOwner(userId);
        allow create: if isOwner(userId)
          && request.resource.data.userId == request.auth.uid;
        allow update: if isOwner(userId)
          && isImmutableField('createdAt')
          && isImmutableField('userId');
        // Soft-delete: no direct client deletes — use the reset endpoint instead
        allow delete: if false;
      }

      // ── apiKeys subcollection ──────────────────────────────────────────────
      // Stores encrypted API keys per network. All writes go through server-side
      // Admin SDK (which bypasses rules), but rules still protect direct client access.
      match /apiKeys/{networkId} {
        allow read: if isOwner(userId);
        allow create: if isOwner(userId)
          && request.resource.data.userId == request.auth.uid;
        allow update: if isOwner(userId)
          && isImmutableField('createdAt')
          && isImmutableField('userId');
        // Hard delete is supported — user can remove a key
        allow delete: if isOwner(userId);
      }
    }

    // ========== apiKeys collection ==========
    match /apiKeys/{docId} {
      allow read: if isResourceOwner();
      allow create: if isAuthenticated()
        && request.resource.data.userId == request.auth.uid;
      allow update: if isResourceOwner();
      allow delete: if false;
    }

    // ========== networkConfigs collection ==========
    match /networkConfigs/{docId} {
      allow read: if isResourceOwner();
      allow create: if isAuthenticated()
        && request.resource.data.userId == request.auth.uid;
      allow update: if isResourceOwner()
        && isImmutableField('userId')
        && isImmutableField('createdAt');
      allow delete: if false;
    }

    // ========== adStats collection ==========
    match /adStats/{docId} {
      allow read: if isResourceOwner();
      allow create: if false; // Server-side only via Admin SDK
      allow update: if isResourceOwner()
        && isImmutableField('uid')
        && isImmutableField('networkId')
        && isImmutableField('date')
        // Reconciliation fields are written server-side only via Admin SDK
        && isImmutableField('validationStatus')
        && isImmutableField('anomalyFlags')
        && isImmutableField('validationCheckedAt')
        && isImmutableField('isReconciled')
        && isImmutableField('reconciledAt');
      allow delete: if false;
    }

    // ========== auditLogs collection ==========
    // Writes are exclusively via the server-side Admin SDK (which bypasses rules).
    // Clients must never write directly to auditLogs.
    match /auditLogs/{docId} {
      allow read: if isResourceOwner();
      allow create: if false;
      allow update: if false;
      allow delete: if false;
    }

    // ========== benchmarks collection ==========
    match /benchmarks/{docId} {
      allow read: if isResourceOwner();
      allow create: if isAuthenticated()
        && request.resource.data.userId == request.auth.uid;
      allow update: if isResourceOwner()
        && isImmutableField('createdAt')
        && isImmutableField('userId');
      // No hard deletes — soft delete only (handled server-side)
      allow delete: if false;
    }

    // ========== workspaceInvitations collection ==========
    match /workspaceInvitations/{docId} {
      // Members of the same workspace can read invitations
      allow read: if isAuthenticated()
        && (resource.data.invitedByUid == request.auth.uid
          || resource.data.acceptedByUid == request.auth.uid
          || resource.data.workspaceId in get(/databases/$(database)/documents/users/$(request.auth.uid)).data.workspaceId);
      // Invitations are created server-side via Admin SDK (bypasses rules)
      allow create: if false;
      // Only the inviting user or owner can update/revoke; createdAt is immutable
      allow update: if isAuthenticated()
        && (resource.data.invitedByUid == request.auth.uid
          || get(/databases/$(database)/documents/users/$(request.auth.uid)).data.workspaceRole == 'owner')
        && isImmutableField('createdAt');
      allow delete: if false;
    }

    // ========== workspacePermissions collection ==========
    match /workspacePermissions/{docId} {
      allow read: if isAuthenticated();
      allow write: if false; // Admin SDK only
    }

    // ========== helpArticles collection ==========
    match /helpArticles/{docId} {
      allow read: if isAuthenticated() && resource.data.isPublished == true;
      allow write: if false; // Admin SDK only
    }

    // ========== cachedResponses collection ==========
    match /cachedResponses/{docId} {
      allow read: if isResourceOwner();
      allow write: if false; // Server-side only
    }

    // ========== Deny all other collections ==========
    match /{document=**} {
      allow read, write: if false;
    }
  }
}
